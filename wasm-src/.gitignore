# ── Rust build outputs ──────────────────────────────────────────────────────
# Cargo will generate these during builds
target/
Cargo.lock

# wasm-pack generates a pkg/ folder (we output to ../wasm/ instead via build script)
**/pkg/

# ── Build artifacts ─────────────────────────────────────────────────────────
# .wasm files and .js bindings generated by wasm-pack are copied to ../wasm/
# by the build scripts. The source artifacts can be safely ignored.
*.wasm
